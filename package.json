{
  "name": "circuitshield",
  "version": "0.1.2",
  "description": "Post-audit invariant drift monitoring and audit gate for ZK circuits.",
  "type": "module",
  "bin": {
    "circuitshield": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "action.yml",
    "docs/github-action.md",
    "docs/sample-reports",
    "docs/validation",
    "examples",
    "benchmarks"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MohdKamranAlam/circuitshield-zk.git"
  },
  "bugs": {
    "url": "https://github.com/MohdKamranAlam/circuitshield-zk/issues"
  },
  "homepage": "https://github.com/MohdKamranAlam/circuitshield-zk#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "dev": "tsx src/cli.ts",
    "api": "tsx src/server.ts",
    "api:built": "node dist/server.js",
    "web:dev": "vite --config web/vite.config.js",
    "web:build": "vite build --config web/vite.config.js",
    "app:build": "npm run build && npm run web:build",
    "scan:example": "tsx src/cli.ts scan examples --config examples/circuitshield.yml --format markdown",
    "baseline:example": "tsx src/cli.ts baseline create --ref audited-v1.0.0 --target examples --config examples/circuitshield.yml",
    "benchmark": "tsx src/cli.ts benchmark benchmarks",
    "demo:baseline": "tsx src/cli.ts demo baseline-drift",
    "test": "npm run build && node tests/init-and-report.test.mjs && node dist/cli.js scan examples --config examples/circuitshield.yml --format json --out .tmp/scan.json && node dist/cli.js benchmark benchmarks --format json --out .tmp/benchmark.json && npm run web:build"
  },
  "keywords": [
    "zk",
    "circom",
    "audit",
    "security",
    "zero-knowledge",
    "zk-snarks",
    "github-action",
    "static-analysis",
    "smart-contracts"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "pg": "^8.13.1",
    "yaml": "^2.5.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/pg": "^8.11.11",
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  },
  "engines": {
    "node": ">=20"
  }
}
